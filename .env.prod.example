# ─────────────────────────────────────────────────────────────────────────────
# AutoClaimX Platform — Production Environment Variables
# Copy to .env.prod and fill in all secrets. NEVER commit .env.prod to git.
# All passwords/secrets must be strong random values — never use dev defaults.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
LOG_LEVEL=info

# ── PostgreSQL ────────────────────────────────────────────────────────────────
# Full DSN used by all NestJS services and Prisma
DATABASE_URL=postgresql://autoclaimx:CHANGE_ME@postgres:5432/autoclaimx
# Used by docker-compose.prod.yml infra service
POSTGRES_USER=autoclaimx
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=autoclaimx

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://autoclaimx:CHANGE_ME@mongo:27017/autoclaimx?authSource=admin
MONGO_USER=autoclaimx
MONGO_PASSWORD=CHANGE_ME

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@redis:6379
REDIS_PASSWORD=CHANGE_ME

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=kafka:29092

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=CHANGE_ME
AWS_SECRET_ACCESS_KEY=CHANGE_ME
S3_MEDIA_BUCKET=autoclaimx-media-prod
S3_DOCS_BUCKET=autoclaimx-docs-prod
S3_MODELS_BUCKET=autoclaimx-models-prod

# ── JWT ── Generate with: openssl rand -hex 64 ────────────────────────────────
JWT_SECRET=CHANGE_ME_64_CHAR_HEX
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# ── Auth (AWS Cognito) ────────────────────────────────────────────────────────
COGNITO_USER_POOL_ID=CHANGE_ME
COGNITO_CLIENT_ID=CHANGE_ME
COGNITO_REGION=ap-southeast-1

# ── Anthropic Claude API ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=CHANGE_ME

# ── Twilio (OTP SMS) ──────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=CHANGE_ME
TWILIO_AUTH_TOKEN=CHANGE_ME
TWILIO_FROM_NUMBER=+1XXXXXXXXXX

# ── AWS SES (Email) ───────────────────────────────────────────────────────────
SES_FROM_EMAIL=noreply@autoclaimx.com

# ── Internal Service Auth ── Generate with: openssl rand -hex 32 ─────────────
INTERNAL_SERVICE_SECRET=CHANGE_ME_32_CHAR_HEX

# ── Web App Public URLs (must be publicly accessible) ────────────────────────
NEXT_PUBLIC_API_URL=https://api.autoclaimx.com
NEXT_PUBLIC_WS_URL=wss://api.autoclaimx.com

# ── Observability ─────────────────────────────────────────────────────────────
# Grafana admin credentials — change before first deploy
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
# Public URL for Grafana (used in dashboard links)
GRAFANA_ROOT_URL=https://grafana.autoclaimx.com
# LOG_LEVEL controls pino/python log verbosity (info | debug | warn | error)
LOG_LEVEL=info

# ── Container Image Tag (set by CI during deploy) ────────────────────────────
IMAGE_TAG=latest
