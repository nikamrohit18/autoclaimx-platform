{
  "uid": "acx-claim-pipeline",
  "title": "AutoClaimX — Claim Pipeline",
  "tags": ["autoclaimx"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "title": "Claims Created (total)",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        { "expr": "sum(claims_created_total)", "legendFormat": "Total Claims" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "id": 2,
      "title": "Claims Created Rate",
      "type": "timeseries",
      "gridPos": { "x": 6, "y": 0, "w": 18, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(claims_created_total[5m]))",
          "legendFormat": "Claims/sec"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "cps" } }
    },
    {
      "id": 3,
      "title": "Status Transitions by Route",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (to_status) (rate(claim_status_transitions_total[5m]))",
          "legendFormat": "→ {{to_status}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 4,
      "title": "Kafka Messages Processed",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (topic) (rate(kafka_messages_processed_total[1m]))",
          "legendFormat": "{{topic}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 5,
      "title": "Negotiation Rounds by Offerer",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (offerer, style) (rate(negotiation_rounds_total[5m]))",
          "legendFormat": "{{offerer}} ({{style}})"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" } }
    },
    {
      "id": 6,
      "title": "Negotiation Outcomes",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (outcome) (negotiation_outcomes_total)",
          "legendFormat": "{{outcome}}"
        }
      ]
    }
  ],
  "time": { "from": "now-1h", "to": "now" }
}
