{
  "uid": "acx-ai-inference",
  "title": "AutoClaimX — AI Inference",
  "tags": ["autoclaimx"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 39,
  "panels": [
    {
      "id": 1,
      "title": "AI Inference Duration P50/P95/P99",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (service, le) (rate(ai_inference_duration_seconds_bucket[5m])))",
          "legendFormat": "{{service}} p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (service, le) (rate(ai_inference_duration_seconds_bucket[5m])))",
          "legendFormat": "{{service}} p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (service, le) (rate(ai_inference_duration_seconds_bucket[5m])))",
          "legendFormat": "{{service}} p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 2,
      "title": "Damage Detection Request Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_count{job=\"damage-detection\"}[1m]))",
          "legendFormat": "Requests/sec"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 3,
      "title": "Fraud ML Request Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_count{job=\"fraud-ml\"}[1m]))",
          "legendFormat": "Requests/sec"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 4,
      "title": "OCR Extraction Request Rate",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_count{job=\"ocr-extraction\"}[1m]))",
          "legendFormat": "Requests/sec"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "id": 5,
      "title": "Negotiation LLM Request Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum(rate(http_request_duration_seconds_count{job=\"negotiation-llm\"}[1m]))",
          "legendFormat": "Requests/sec"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    }
  ],
  "time": { "from": "now-1h", "to": "now" }
}
