# ─────────────────────────────────────────────────────────────────────────────
# AutoClaimX Platform — Environment Variables
# Copy this to .env and fill in your values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://autoclaimx:autoclaimx_secret@localhost:5432/autoclaimx
DATABASE_SHADOW_URL=postgresql://autoclaimx:autoclaimx_secret@localhost:5432/autoclaimx_shadow

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://autoclaimx:autoclaimx_secret@localhost:27017/autoclaimx?authSource=admin

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Neo4j ─────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=autoclaimx_secret

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ── AWS ───────────────────────────────────────────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_MEDIA_BUCKET=autoclaimx-media-dev
S3_DOCS_BUCKET=autoclaimx-docs-dev
S3_MODELS_BUCKET=autoclaimx-models-dev

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-secret-in-production
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# ── Auth (AWS Cognito) ────────────────────────────────────────────────────────
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
COGNITO_REGION=ap-southeast-1

# ── Anthropic Claude API ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Twilio (OTP SMS) ──────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── AWS SES (Email) ───────────────────────────────────────────────────────────
SES_FROM_EMAIL=noreply@autoclaimx.com

# ── Service Ports ─────────────────────────────────────────────────────────────
API_GATEWAY_PORT=3000
CLAIMS_SERVICE_PORT=3001
WORKSHOP_SERVICE_PORT=3002
ADMIN_SERVICE_PORT=3003

# ── Python AI Services ────────────────────────────────────────────────────────
DAMAGE_DETECTION_URL=http://localhost:8001
NEGOTIATION_LLM_URL=http://localhost:8002
FRAUD_ML_URL=http://localhost:8003
OCR_EXTRACTION_URL=http://localhost:8004

# ── Email Notifications (optional — leave SMTP_HOST blank to disable) ─────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@autoclaimx.com
DEFAULT_ADJUSTER_EMAIL=

# ── Internal Service Auth ─────────────────────────────────────────────────────
INTERNAL_SERVICE_SECRET=change-me-internal-secret
